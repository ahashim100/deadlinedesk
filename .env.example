# ----------------------------------------------------------------------------
# DeadlineDesk environment variables
# Copy this file to `.env.local` and fill in your own values.
# NEVER commit `.env.local`. Anything starting with NEXT_PUBLIC_ is exposed to
# the browser — keep secrets out of those.
# ----------------------------------------------------------------------------

# --- Supabase (Project Settings → API) --------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — SECRET. Used by the Stripe webhook and the seed script.
# Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App URL ----------------------------------------------------------------
# Used to build Stripe success/cancel/return URLs. Set to your deployed URL in
# production (e.g. https://deadlinedesk.vercel.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Stripe (Developers → API keys) -----------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
# The recurring Price ID for the ~$10/month plan (Products → your product).
STRIPE_PRICE_ID=price_xxx
# Webhook signing secret (Developers → Webhooks → your endpoint).
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ----------------------------------------------------------------------------
# The following are used by the Supabase Edge Function (daily-reminders), NOT
# the Next.js app. Set them as Supabase function secrets, not in .env.local:
#   supabase secrets set RESEND_API_KEY=... EMAIL_FROM=... TWILIO_ACCOUNT_SID=...
# They are listed here for reference.
# ----------------------------------------------------------------------------

# --- Resend (email) ---------------------------------------------------------
# RESEND_API_KEY=re_xxx
# EMAIL_FROM="DeadlineDesk <reminders@yourdomain.com>"

# --- Twilio (SMS) -----------------------------------------------------------
# TWILIO_ACCOUNT_SID=ACxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM_NUMBER=+15551234567
